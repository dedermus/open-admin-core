{
  "name": "laravel-packages/open-admin-core",
  "description": "Ядро админки для Laravel 13",
  "keywords": ["laravel", "admin", "administrator", "adminlte", "dashboard"],
  "license": "MIT",
  "homepage": "https://github.com/dedermus/open-admin-core",
  "authors": [
    {
      "name": "Aleksandr Lomovtsev",
      "email": "your-email@example.com",
      "role": "Maintainer"
    }
  ],
  "require": {
    "php": "^8.3",
    "laravel/framework": "^13.0",
    "ext-fileinfo": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0",
    "larastan/larastan": "^3.0",
    "phpstan/phpstan": "^2.0",
    "laravel/pint": "^1.18"
  },
  "autoload": {
    "psr-4": {
      "OpenAdminCore\\Admin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OpenAdminCore\\Admin\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "OpenAdminCore\\Admin\\AdminServiceProvider"
      ],
      "aliases": {
        "Admin": "OpenAdminCore\\Admin\\Facades\\Admin"
      }
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "analyse": "phpstan analyse",
    "format": "pint",
    "check": [
      "@format",
      "@analyse",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}